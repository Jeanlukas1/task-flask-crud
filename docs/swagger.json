{
  "openapi": "3.0.0",
  "info": {
    "title": "API de Gerenciamento de Tarefas",
    "description": "API CRUD para gerenciar tarefas (To-Do List)",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://virtserver.swaggerhub.com/idk-782/Task-Flask-Crud/1.0.0",
      "description": "SwaggerHub API Auto Mocking"
    },
    {
      "url": "http://localhost:5000"
    }
  ],
  "paths": {
    "/tasks": {
      "get": {
        "tags": [
          "Tasks"
        ],
        "summary": "Listar todas as tarefas",
        "responses": {
          "200": {
            "description": "Lista de tarefas obtidas com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/inline_response_200"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Tasks"
        ],
        "summary": "Criar uma nova tarefa",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskInput"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Tarefa criada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{id}": {
      "put": {
        "tags": [
          "Tasks"
        ],
        "summary": "Atualizar uma tarefa",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskInput"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Tarefa atualizada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "404": {
            "description": "Tarefa não encontrada"
          }
        }
      },
      "delete": {
        "tags": [
          "Tasks"
        ],
        "summary": "Deletar uma tarefa",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tarefa deletada com sucesso"
          },
          "404": {
            "description": "Tarefa não encontrada"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Estudar Flask"
          },
          "description": {
            "type": "string",
            "example": "Aprender a criar APIs com Flask"
          },
          "completed": {
            "type": "boolean",
            "example": false
          }
        }
      },
      "TaskInput": {
        "required": [
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Estudar Swagger"
          },
          "description": {
            "type": "string",
            "example": "Documentar API com OpenAPI"
          },
          "completed": {
            "type": "boolean",
            "example": false
          }
        }
      },
      "inline_response_200": {
        "type": "object",
        "properties": {
          "tasks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Task"
            }
          },
          "total_tasks": {
            "type": "integer",
            "example": 0
          }
        }
      }
    }
  }
}